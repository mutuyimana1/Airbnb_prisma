generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  password         String
  phone            String?
  role             Role      @default(GUEST)
  avatar           String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  avatarPublicId   String?
  bookings         Booking[]
  listings         Listing[]
  profile          profile?
  reviews          Review[]

  @@index([name])
  @@index([role])
}

model Listing {
  id            String         @id @default(uuid())
  title         String
  description   String
  pricePerNight Float
  guests        Int
  userId        String
  type          ListingType    @default(APARTMENT)
  emenities     String[]
  ratings       Float[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hostId        String
  location      String
  bookings      Booking[]
  host          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos        ListingPhoto[]
  reviews       Review[]

  @@index([userId])
  @@index([location])
  @@index([type])
  @@index([pricePerNight])
}

model Booking {
  id         String        @id @default(uuid())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  listingId  String
  guestId    String
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}
model Review {
  id        String      @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}
model profile {
  id      Int    @id @default(autoincrement())
  bio     String
  website String
  country String
  avatar  String
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListingPhoto {
  id        Int     @id @default(autoincrement())
  url       String
  publicId  String
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

enum Role {
  HOST
  GUEST
  ADMIN
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
